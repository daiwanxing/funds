{
  "plugins": ["typescript", "unicorn", "oxc", "import"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": "error",
    "func-style": ["error", "expression"],
    "no-console": "warn",
    "eqeqeq": "error",
    "import/no-unassigned-import": "off"
  },
  "ignorePatterns": [
    "dist/**/*",
    "docs/**/*",
    "lib/**/*",
    "node_modules/**/*",
    "src/icons/**/*",
    "*.config.ts",
    "*.config.js"
  ]
}
