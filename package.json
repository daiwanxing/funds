{
  "name": "funds-web",
  "version": "3.0.0",
  "private": true,
  "description": "自选基金助手 - Web 版",
  "author": "LiuRabt",
  "license": "GPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:vercel": "npx vercel dev",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src api",
    "lint:fix": "eslint src api --fix",
    "type-check": "vue-tsc --noEmit && tsc --noEmit --project api/tsconfig.json",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "vercel:pull-env": "npx vercel env pull .env.local --yes",
    "supabase:db:push": "npx supabase db push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/vue-query": "^5.95.2",
    "axios": "^1.7.0",
    "echarts": "^5.5.0",
    "file-saver": "^2.0.5",
    "lucide-vue-next": "^1.0.0",
    "motion": "^12.38.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.5.0",
    "@unocss/reset": "^66.6.7",
    "@vercel/node": "^5.6.22",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^25.0.0",
    "oxfmt": "^0.42.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "unocss": "^66.0.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  }
}
