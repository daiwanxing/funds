    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "oxfmt": "^0.5.0",
    "oxlint": "^0.16.0",
    "typescript": "^5.7.0",
    "unocss": "^66.0.0",
