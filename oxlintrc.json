{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn",
    "style": "off"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "eqeqeq": "error",
    "import/no-unassigned-import": "off"
  },
  "ignorePatterns": [
    "dist/",
    "docs/",
    "lib/",
    "node_modules/",
    "src/icons/",
    "*.config.ts",
    "*.config.js"
  ]
}
